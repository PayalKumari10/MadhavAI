# Backend & Infrastructure Environment Configuration
# This file contains secrets for backend services and CI/CD workflows
# Copy this file to .env.backend and fill in your actual values
# DO NOT commit .env.backend to version control

# ============================================
# CI/CD & Security
# ============================================

# Snyk Security Scanning (used by backend-ci-cd.yml)
# Get token from: https://app.snyk.io/account
SNYK_TOKEN=your_snyk_token_here

# ============================================
# Infrastructure Alerts
# ============================================

# Email for infrastructure alerts (used by Terraform and Lambda functions)
ALERT_EMAIL=team@example.com

# Slack webhook for deployment notifications (used by backend-ci-cd.yml)
# Create webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# Backend API URLs
# ============================================

# Staging API URL (used for E2E tests in backend-ci-cd.yml)
STAGING_API_URL=https://staging-api.madhavai.com

# Production API URL
PRODUCTION_API_URL=https://api.madhavai.com

# ============================================
# AWS Configuration (Backend Services)
# ============================================

# AWS Credentials (for backend deployment)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# ============================================
# Database Configuration
# ============================================

# DynamoDB Tables
LESSONS_TABLE=farmer-platform-lessons
PROGRESS_TABLE=farmer-platform-learning-progress
SCHEMES_TABLE=farmer-platform-schemes
ALERTS_TABLE=farmer-platform-alerts

# ============================================
# Storage Configuration
# ============================================

# S3 Buckets
CONTENT_BUCKET=farmer-platform-training-content
UPLOADS_BUCKET=farmer-platform-uploads
BACKUPS_BUCKET=farmer-platform-backups

# ============================================
# Disaster Recovery
# ============================================

# Primary and backup regions (used by Lambda functions)
PRIMARY_REGION=us-east-1
BACKUP_REGION=us-west-2

# SNS Topic for alerts
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:xxxxxxxxxxxx:madhavai-alerts

# ============================================
# Monitoring & Logging
# ============================================

# CloudWatch Log Group
LOG_GROUP=/aws/lambda/madhavai

# Monitoring retention (days)
LOG_RETENTION_DAYS=30

# ============================================
# Project Configuration
# ============================================

PROJECT_NAME=madhavai
ENVIRONMENT=development

# ============================================
# Notes
# ============================================
# 
# This file is for BACKEND/INFRASTRUCTURE secrets only.
# For mobile app secrets, see .env.example
#
# GitHub Secrets Required (for CI/CD):
# - SNYK_TOKEN
# - AWS_ACCESS_KEY_ID
# - AWS_SECRET_ACCESS_KEY
# - ALERT_EMAIL
# - STAGING_API_URL
# - SLACK_WEBHOOK
# - GOOGLE_PLAY_SERVICE_ACCOUNT_JSON (for mobile builds)
# - ANDROID_KEYSTORE_BASE64 (for mobile builds)
# - ANDROID_KEYSTORE_PASSWORD (for mobile builds)
# - ANDROID_KEY_ALIAS (for mobile builds)
# - ANDROID_KEY_PASSWORD (for mobile builds)
