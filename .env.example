# Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
# 
# NOTE: This file is for MOBILE APP secrets only.
# For backend/infrastructure secrets, see .env.backend.example

# ============================================
# API Configuration
# ============================================
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=30000
ENABLE_API=false

# OTA Update Service API (used by OTAUpdateService, FeatureUpdateScheduler, ABTestingService, VersionCompatibilityService)
OTA_API_BASE_URL=https://api.madhavai.app

# ============================================
# Android Build Secrets (for local release builds)
# ============================================
ANDROID_KEYSTORE_PASSWORD=your_keystore_password_here
ANDROID_KEY_ALIAS=your_key_alias_here
ANDROID_KEY_PASSWORD=your_key_password_here

# ============================================
# AWS Configuration
# ============================================
# AWS Credentials (for Amplify CLI and backend services)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# AWS Amplify API (AppSync GraphQL)
AWS_APPSYNC_GRAPHQL_ENDPOINT=https://your-appsync-endpoint.appsync-api.us-east-1.amazonaws.com/graphql
AWS_APPSYNC_API_KEY=your_appsync_api_key_here
AWS_APPSYNC_REGION=us-east-1

# AWS Cognito (Authentication)
AWS_COGNITO_REGION=us-east-1
AWS_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
AWS_COGNITO_USER_POOL_WEB_CLIENT_ID=your_cognito_client_id
AWS_COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================
# Lambda Function Environment Variables
# ============================================
# Disaster Recovery Configuration (used by infrastructure/lambda/dr-test and failover-handler)
PRIMARY_REGION=us-east-1
BACKUP_REGION=us-west-2
PROJECT_NAME=madhavai
ENVIRONMENT=development
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:xxxxxxxxxxxx:madhavai-alerts

# Training Content Configuration (used by src/api/handlers/trainingHandlers.ts)
LESSONS_TABLE=farmer-platform-lessons
PROGRESS_TABLE=farmer-platform-learning-progress
CONTENT_BUCKET=farmer-platform-training-content

# ============================================
# Google Play Store (for automated uploads)
# ============================================
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_PATH=./android/play-store/service-account.json

# ============================================
# Storage Configuration
# ============================================
STORAGE_LIMIT_MB=500
SYNC_INTERVAL_MS=60000
MAX_RETRY_ATTEMPTS=3
